# ─── Build artifacts (regenerated by build_template.bat) ──────────────────────
# Built world templates — both the latest one at the repo root and the archive.
*.mctemplate
/Templates/

# Post-build pristine COPY of the behavior pack. The source of truth is /FF_BP;
# this copy is stamped out by build_template.bat on every build.
/FB_Template/behavior_packs/

# ─── Tooling output ───────────────────────────────────────────────────────────
# Syntax-checker report (see tools/check_syntax.bat)
/tools/syntax_check_result.txt

# Python caches
__pycache__/
*.pyc

# Node (only present if you install it for the syntax checker)
node_modules/

# ─── Editor / OS cruft ────────────────────────────────────────────────────────
.vscode/
.idea/
Thumbs.db
desktop.ini
.DS_Store
